{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node", "bun-types", "vite/client"]
	},
	"include": ["src", "penx.ts", "vite.config.ts", "esm-sh.d.ts"]
}

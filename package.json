{
	"name": "codepen",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "eslint .",
		"check": "tsc && bun run format -c && bun run lint && bun run build",
		"format": "prettier -w . !\"bun.lockb\"",
		"get-latest": "bun update --latest -i",
		"reinstall": "rm -rf node_modules && rm bun.lock && bun install",
		"penx": "bun scripts/penx.ts"
	},
	"dependencies": {
		"@inquirer/prompts": "^7.4.0",
		"@trenaryja/ui": "^0.0.1-35",
		"d3-selection": "^3.0.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@fullstacksjs/eslint-config": "^14.0.1",
		"@types/d3-selection": "^3.0.11",
		"@types/node": "^25.3.0",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"bun-types": "^1.3.9",
		"eslint": "^10.0.2",
		"typescript": "^5.7.3",
		"vite": "^6.1.0"
	},
	"prettier": {
		"semi": false,
		"singleQuote": true,
		"printWidth": 120,
		"jsxSingleQuote": true,
		"useTabs": true
	}
}

{
	"name": "codepen",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"lint": "eslint .",
		"check": "tsc && bun run format -c && bun run lint && ./penx.ts check",
		"format": "prettier -w . !\"bun.lockb\"",
		"get-latest": "bun update --latest -i",
		"reinstall": "rm -rf node_modules && rm bun.lock && bun install",
		"penx": "./penx.ts"
	},
	"dependencies": {
		"@mantine/hooks": "^8.3.18",
		"@trenaryja/ui": "^0.0.1-35",
		"d3-selection": "^3.0.0",
		"honeycomb-grid": "4.1.5",
		"qrcode": "^1.5.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-icons": "^5.6.0"
	},
	"devDependencies": {
		"@clack/prompts": "^1.1.0",
		"@fullstacksjs/eslint-config": "^14.0.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-selection": "^3.0.11",
		"@types/node": "^25.5.0",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"bun-types": "^1.3.11",
		"commander": "^14.0.3",
		"eslint": "^10.1.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.2"
	},
	"prettier": {
		"semi": false,
		"singleQuote": true,
		"printWidth": 120,
		"jsxSingleQuote": true,
		"useTabs": true
	}
}
